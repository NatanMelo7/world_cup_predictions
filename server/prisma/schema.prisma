generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  displayName String   @unique
  avatarUrl   String?
  xp          Int      @default(0)
  level       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  predictions        Prediction[]
  userAchievements   UserAchievement[]
  specialPredictions SpecialPrediction[]
}

model Group {
  id   String @id
  name String @unique

  teams Team[]
}

model Team {
  id    String @id
  name  String
  flag  String
  groupId String

  group Group @relation(fields: [groupId], references: [id])
}

model Match {
  id          String   @id @default(uuid())
  externalId  String?  @unique
  teamA       String
  teamB       String
  flagA       String?
  flagB       String?
  matchDate   DateTime
  phase       String
  timeElapsed String   @default("notstarted")
  scoreA      Int?
  scoreB      Int?

  predictions Prediction[]
}

model Prediction {
  id              String   @id @default(uuid())
  userId          String
  matchId         String
  predictedScoreA Int
  predictedScoreB Int
  xpEarned        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

model LevelThreshold {
  id         Int @id @default(autoincrement())
  level      Int @unique
  xpRequired Int
}

model Achievement {
  id          String @id @default(uuid())
  name        String @unique
  description String
  icon        String

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model SpecialPrediction {
  id                    String   @id @default(uuid())
  userId                String
  type                  String
  predictedTeamOrPlayer String
  xpEarned              Int?
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}
